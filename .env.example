# ─────────────────────────────────────────────
#  AQCS — Environment Variables Template
#  Copy to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Exchange credentials (READ-ONLY keys only) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Data storage ──
DATA_ROOT=./data
LOGS_ROOT=./logs

# ── Environment ──
AQCS_ENV=development      # development | staging | production

# ── Logging ──
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ── Feature flags ──
ENABLE_LIVE_DATA=false    # set to true only for read-only market data
