# ─────────────────────────────────────────────
#  AQCS — Environment Variables Template
#  Copy to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Exchange credentials (READ-ONLY keys only) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Data storage ──
DATA_ROOT=./data
LOGS_ROOT=./logs

# ── Environment ──
# Valid values: development | staging | production
AQCS_ENV=development

# ── Logging ──
# Valid values: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Feature flags ──
# Set to true only for read-only market data
ENABLE_LIVE_DATA=false
